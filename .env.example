# ─────────────────────────────────────────────────────────
# ProactifSystème — Variables d'environnement
# Copier ce fichier en ".env" et remplir les valeurs réelles
# NE JAMAIS COMMITTER le fichier .env sur GitHub
# ─────────────────────────────────────────────────────────

# ── Serveur ───────────────────────────────────────────────
NODE_ENV=production
PORT=3002

# ── Chiffrement des données (OBLIGATOIRE au démarrage) ────
# Génère une clé forte avec PowerShell :
# $rng = [System.Security.Cryptography.RandomNumberGenerator]::Create(); $b = New-Object byte[] 32; $rng.GetBytes($b); [Convert]::ToBase64String($b)
DATA_ENCRYPTION_KEY=REMPLACER_PAR_UNE_CLÉ_ALÉATOIRE_BASE64

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Perplexity ────────────────────────────────────────────
PPLX_API_KEY=pplx-...

# ── SMTP IONOS ────────────────────────────────────────────
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=465
IONOS_EMAIL=contact@proactifsystem.com
IONOS_PASS=MOT_DE_PASSE_IONOS

# ── Emails ────────────────────────────────────────────────
FROM_EMAIL=contact@proactifsystem.com
ADMIN_EMAIL=ton.email@proactifsystem.com
ALERT_EMAIL_USER=contact@proactifsystem.com

# ── reCAPTCHA (optionnel) ─────────────────────────────────
RECAPTCHA_SITE_KEY=6LeAVAksAAAAAJCJqveZyvOWyJ12B3dhPexH2y5G

# ── Options avancées ──────────────────────────────────────
MAINTENANCE_MODE=false
CSP_INLINE=false
